# PostHog Analytics Configuration
# Get your API key from: https://app.posthog.com/project/settings
VITE_POSTHOG_API_KEY=your-posthog-api-key-here

# Optional: Custom PostHog host (defaults to https://app.posthog.com)
# VITE_POSTHOG_HOST=https://your-custom-posthog-host.com

# Browser engine for extension background.
# BrowserManager companion mode is the only supported engine.
VITE_BROWSER_ENGINE=agent-browser

# Localhost companion websocket endpoint (used when VITE_BROWSER_ENGINE=agent-browser)
VITE_AGENT_BROWSER_WS_URL=ws://127.0.0.1:9223

# Optional token expected by companion hello handshake
# VITE_AGENT_BROWSER_WS_TOKEN=replace-with-a-strong-token
